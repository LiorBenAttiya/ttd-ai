# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ttdai
# Supabase: postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── WhatsApp / Meta ───────────────────────────────────────────
WA_VERIFY_TOKEN=your-webhook-verify-token
WA_ACCESS_TOKEN=your-meta-access-token
WA_PHONE_NUMBER_ID=your-phone-number-id
WA_OWNER_PHONE=972501234567

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Microsoft Graph (Outlook) ─────────────────────────────────
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-app-client-id
AZURE_CLIENT_SECRET=your-app-client-secret
GRAPH_REDIRECT_URI=https://your-api-domain.com/api/v1/mailboxes/oauth/callback

# ── Twilio (fallback WA) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WA_NUMBER=whatsapp:+14155238886

# ── Azure Key Vault ───────────────────────────────────────────
AZURE_KEY_VAULT_URL=https://kv-ttdai-prod.vault.azure.net/
# Leave empty in local dev — app reads secrets from .env instead

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,https://your-frontend-domain.com
LOG_LEVEL=INFO
