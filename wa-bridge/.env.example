# TTD AI backend API
BACKEND_URL=http://localhost:8000
BACKEND_TOKEN=         # will be auto-fetched via /api/v1/auth/dev-token

# Your personal WhatsApp number (owner) — messages from other numbers are ignored
OWNER_PHONE=972543090009   # format: country code + number, no +

# Bridge port
PORT=3001

# Session storage path (keeps you logged in across restarts)
SESSION_PATH=./.wwebjs_auth
